generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model entries {
  id          Int     @id @default(autoincrement())
  feedId      Int
  entryId     String
  title       String  @default("")
  link        String  @default("")
  author      String  @default("")
  published   String  @default("")
  updated     String?
  description String  @default("")
  thumbnail   String?
  content     String?
  openedAt    String?
  archivedAt  String?
  starredAt   String?
  feeds       feeds   @relation(fields: [feedId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([feedId, entryId])
}

model feeds {
  id                  Int        @id @default(autoincrement())
  title               String
  description         String     @default("")
  link                String     @unique
  feedUrl             String     @default("")
  author              String     @default("")
  published           String     @default("")
  image               String?
  fetchedAt           String?
  refreshIntervalMins Int? // NULL disables automatic background refresh for this feed.
  // relations
  entries             entries[]
  feedTags            FeedTags[]
}

model FeedTags {
  feedId Int
  tagId  Int
  feeds  feeds @relation(fields: [feedId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tags   Tags  @relation(fields: [tagId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([feedId, tagId])
}

model Tags {
  id       Int        @id @default(autoincrement())
  name     String     @unique
  // relations
  feedTags FeedTags[]
}
