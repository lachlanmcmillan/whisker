{
  "name": "whisker",
  "private": true,
  "workspaces": {
    "packages": [
      "common",
      "client",
      "server"
    ],
    "catalog": {
      "typescript": "~6.0.2"
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "chalk": "^5.6.2",
    "prettier": "^3.8.1",
    "typescript": "catalog:"
  },
  "scripts": {
    "dev": "bun run --parallel --filter @whisker/server --filter @whisker/client dev",
    "prettier": "prettier --write \"**/src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "deploy-server-ssh": "bun run ./scripts/deploy-server-ssh.ts",
    "db:pull-latest-prod": "bun run ./scripts/download-db.ts",
    "tsc": "bun run --sequential --filter @whisker/server --filter @whisker/client tsc"
  }
}
